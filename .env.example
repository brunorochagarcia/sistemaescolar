# ─── Banco de dados ───────────────────────────────────────────────────────────
# Local (Docker):  postgresql://postgres:postgres@localhost:5432/sistemaescolar
# Neon (produção): postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sistemaescolar"

# ─── NextAuth v5 ──────────────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
AUTH_SECRET="change-me-before-production"

# ─── Resend (e-mail) ──────────────────────────────────────────────────────────
# Obter em: https://resend.com/api-keys
# Portfólio sem domínio próprio: usar onboarding@resend.dev como RESEND_FROM_EMAIL
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# ─── Cron protection ──────────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
# Mesmo valor deve estar configurado no cron-job.org como header Authorization: Bearer ...
CRON_SECRET="change-me-before-production"

# ─── URL pública ──────────────────────────────────────────────────────────────
# Local: http://localhost:3000
# Produção: https://seu-projeto.vercel.app
NEXT_PUBLIC_URL="http://localhost:3000"
